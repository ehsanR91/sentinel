{
  "name": "sentinelcore-frontend",
  "version": "1.0.0",
  "description": "SentinelCore — Self-hosted Linux security, monitoring, and operations dashboard",
  "private": true,
  "scripts": {
    "serve": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.vue",
    "generate:pwa-assets": "node scripts/generate-pwa-assets.js"
  },
  "dependencies": {
    "@vueuse/core": "^12.8.2",
    "axios": "^1.16.0",
    "bootstrap": "^5.3.3",
    "core-js": "^3.49.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.4",
    "reka-ui": "^2.9.7",
    "sweetalert2": "^11.12.0",
    "v-click-outside": "^3.2.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "vue-sweetalert2": "^5.0.11",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.32.0",
    "pwa-asset-generator": "^8.1.4",
    "sass": "^1.99.0",
    "sass-loader": "^14.2.1",
    "sharp": "^0.32.3",
    "vite": "^5.4.19",
    "vite-plugin-pwa": "^0.18.2",
    "web-vitals": "^3.3.0",
    "workbox-window": "^7.4.1"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "parserOptions": {
      "ecmaVersion": 2022
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "rules": {
      "vue/multi-word-component-names": "off",
      "vue/no-restricted-syntax": [
        "warn",
        {
          "selector": "VElement[rawName=/^[a-z]+(?:-[a-z]+)*$/] > VStartTag > VAttribute[directive=false][key.name='title']",
          "message": "Use the shared Tooltip component instead of a native title attribute."
        },
        {
          "selector": "VElement[rawName=/^[a-z]+(?:-[a-z]+)*$/] > VStartTag > VAttribute[directive=true][key.argument.name='title']",
          "message": "Use the shared Tooltip component instead of a native title binding."
        }
      ],
      "no-inner-declarations": "off",
      "vue/no-reserved-component-names": "off",
      "vue/no-mutating-props": "off",
      "vue/no-unused-components": "off",
      "no-unused-vars": "warn",
      "no-empty": [
        "error",
        {
          "allowEmptyCatch": true
        }
      ]
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
